<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout HomeActivity.
    Struktur:
    DrawerLayout
      ├── CoordinatorLayout (konten utama)
      │     ├── AppBarLayout (Toolbar + status)
      │     └── FrameLayout
      │           ├── Controller Panel (background ungu + 4 tombol)
      │           └── Gas Alert Overlay (muncul saat gas terdeteksi)
      └── NavigationView (drawer menu dari kiri)
-->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- ==================== KONTEN UTAMA ==================== -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/home_bg">

        <!-- AppBar: Toolbar -->
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/navbar_bg"
            app:elevation="4dp">

            <!-- Toolbar: hamburger menu + nama app + status + tombol reconnect -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:minHeight="48dp"
                app:contentInsetStartWithNavigation="0dp">

                <!-- Konten toolbar disusun horizontal -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingEnd="8dp">

                    <!-- Status koneksi Bluetooth (di sebelah kiri judul) -->
                    <TextView
                        android:id="@+id/tv_connection_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="● Tidak Terhubung"
                        android:textColor="#FF5555"
                        android:textSize="12sp"
                        android:paddingStart="8dp"/>

                    <!-- Tombol Reconnect di sebelah kanan -->
                    <Button
                        android:id="@+id/btn_reconnect"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Reconnect"
                        android:textSize="12sp"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/colorAccent"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

                </LinearLayout>
            </androidx.appcompat.widget.Toolbar>
        </com.google.android.material.appbar.AppBarLayout>

        <!-- ==================== AREA CONTROLLER ==================== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior"
            android:padding="16dp">

            <!-- Panel controller utama: background gradien ungu + 4 tombol arah -->
            <LinearLayout
                android:id="@+id/controller_panel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_controller_panel">

                <!-- ===== Grup tombol KIRI (Atas & Bawah - vertikal) ===== -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="80dp">

                    <!-- Tombol Maju (Atas) -->
                    <ImageButton
                        android:id="@+id/btn_up"
                        android:layout_width="85dp"
                        android:layout_height="85dp"
                        android:background="@drawable/btn_action"
                        android:src="@drawable/ic_arrow_up"
                        android:contentDescription="Maju"
                        android:layout_marginBottom="12dp"
                        android:scaleType="centerInside"
                        android:padding="20dp"/>

                    <!-- Tombol Mundur (Bawah) -->
                    <ImageButton
                        android:id="@+id/btn_down"
                        android:layout_width="85dp"
                        android:layout_height="85dp"
                        android:background="@drawable/btn_action"
                        android:src="@drawable/ic_arrow_down"
                        android:contentDescription="Mundur"
                        android:scaleType="centerInside"
                        android:padding="20dp"/>

                </LinearLayout>

                <!-- ===== Grup tombol KANAN (Kiri & Kanan - horizontal) ===== -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- Tombol Kiri -->
                    <ImageButton
                        android:id="@+id/btn_left"
                        android:layout_width="85dp"
                        android:layout_height="85dp"
                        android:background="@drawable/btn_action"
                        android:src="@drawable/ic_arrow_left"
                        android:contentDescription="Kiri"
                        android:layout_marginEnd="12dp"
                        android:scaleType="centerInside"
                        android:padding="20dp"/>

                    <!-- Tombol Kanan -->
                    <ImageButton
                        android:id="@+id/btn_right"
                        android:layout_width="85dp"
                        android:layout_height="85dp"
                        android:background="@drawable/btn_action"
                        android:src="@drawable/ic_arrow_right"
                        android:contentDescription="Kanan"
                        android:scaleType="centerInside"
                        android:padding="20dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ==================== GAS ALERT OVERLAY ==================== -->
            <!--
                Overlay ini muncul di atas semua view saat sensor gas mendeteksi bahaya.
                Dimulai GONE (tersembunyi), diubah jadi VISIBLE dari HomeActivity.
            -->
            <LinearLayout
                android:id="@+id/gas_alert_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#CC1A0000"
                android:visibility="gone"
                android:padding="32dp">

                <!-- Ikon peringatan -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️"
                    android:textSize="56sp"
                    android:layout_marginBottom="16dp"/>

                <!-- Pesan alert -->
                <TextView
                    android:id="@+id/tv_gas_alert"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Gas Berbahaya Terdeteksi!"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Segera jauhi area! Buzzer aktif."
                    android:textColor="#FFCCCC"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginBottom="24dp"/>

                <!-- Tombol untuk menutup alert -->
                <Button
                    android:id="@+id/btn_dismiss_alert"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tutup Peringatan"
                    android:textColor="@color/white"
                    android:backgroundTint="#CC333333"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            </LinearLayout>

        </FrameLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- ==================== NAVIGATION DRAWER ==================== -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="240dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/drawer_bg"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_menu"
        app:itemTextColor="#000000"
        app:itemIconTint="@color/accent_yellow"/>

</androidx.drawerlayout.widget.DrawerLayout>
