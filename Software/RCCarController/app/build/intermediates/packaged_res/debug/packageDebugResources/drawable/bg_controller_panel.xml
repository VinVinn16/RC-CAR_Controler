<?xml version="1.0" encoding="utf-8"?>
<!--
    Background panel controller utama.
    Gradien dari biru-ungu (kiri) ke ungu (kanan), sesuai gambar referensi.
    Corner radius besar agar tampak modern dan rounded.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Gradien horizontal: biru-ungu → ungu magenta -->
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="#5B3FBE"
        android:centerColor="#7B2DBE"
        android:endColor="#A020A0"/>

    <!-- Rounded corners yang besar -->
    <corners android:radius="20dp"/>

</shape>
