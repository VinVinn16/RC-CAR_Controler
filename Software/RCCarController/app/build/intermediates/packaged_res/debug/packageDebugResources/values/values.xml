<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="accent_purple">#007BFF</color>
    <color name="accent_purple_dark">#003C8F</color>
    <color name="accent_yellow">#FFD400</color>
    <color name="colorAccent">#FFD400</color>
    <color name="colorPrimary">#007BFF</color>
    <color name="colorPrimaryDark">#003C8F</color>
    <color name="drawer_bg">#FFFFFF</color>
    <color name="home_bg">#FFFFFF</color>
    <color name="navbar_bg">#0037FF</color>
    <color name="settings_bg">#EAF4FF</color>
    <color name="splash_bg">#003C8F</color>
    <color name="status_connected">#24CE03</color>
    <color name="status_connecting">#F4BA49</color>
    <color name="status_disconnected">#FF0000</color>
    <color name="white">#FFFFFF</color>
    <string name="app_name">RC-Car Controller</string>
    <string name="btn_reconnect">Reconnect</string>
    <string name="menu_settings">Pengaturan</string>
    <string name="nav_close">Tutup Menu</string>
    <string name="nav_open">Buka Menu</string>
    <style name="ColorPickerDialogTheme" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorAccent">@color/accent_yellow</item>
    </style>
    <style name="Theme.RCCarController" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorPrimaryDark">@color/accent_purple_dark</item>
        <item name="colorAccent">@color/accent_yellow</item>
        <item name="android:windowBackground">@color/home_bg</item>
        
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    <style name="Theme.RCCarController.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@color/splash_bg</item>
    </style>
</resources>